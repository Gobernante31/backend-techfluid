# Backend env example
# Cloudflare D1 binding name or connection string in production
# In Wrangler you can set a D1 binding name and value in wrangler.toml or secrets
# Example: D1_DB=techfluid_db
D1_DB=

# Allowed CORS origins (comma separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Optional: R2 or object storage for images
# R2_BUCKET=my-bucket
R2_BUCKET=

# Do NOT commit real secrets. Use your cloud provider secret manager or wrangler secrets.
